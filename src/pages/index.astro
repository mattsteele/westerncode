---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import OfficeBackground from "@/assets/images/office.jpg";
---

<Layout>
	<section class="flex items-center justify-center px-4 sm:px-6 lg:px-8">
		<div class="relative mx-auto my-8 w-full max-w-6xl sm:my-12 md:my-16">
			<Image
				src={OfficeBackground}
				alt="Modern office workspace representing Western Code's professional development environment"
				class="h-auto w-full rounded-lg shadow-lg"
				widths={[320, 640, 768, 1024, 1280]}
				sizes="(max-width: 768px) 100vw, (max-width: 1024px) 90vw, 80vw"
				format="webp"
				quality={85}
				loading="eager"
				fetchpriority="high"
			/>

			<h1
				class="hero-title absolute top-4 left-2 text-xl leading-tight font-semibold text-slate-800 uppercase sm:top-6 sm:left-4 sm:text-2xl md:top-8 md:left-6 md:text-3xl lg:top-12 lg:text-4xl xl:text-5xl"
			>
				<span class="hero-text-bg">Modern Software Development</span><br />
				<span class="hero-text-bg">for Agencies &amp; Businesses</span>
			</h1>
		</div>
	</section>
</Layout>
