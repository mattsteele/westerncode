---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found | Western Code">
	<section
		class="flex flex-col items-center justify-center px-4 py-24 text-center"
	>
		<h1 class="mb-4 text-6xl font-bold">404</h1>
		<p class="mb-8 text-xl text-gray-600 dark:text-gray-400">Page not found.</p>
		<a
			href="/"
			class="rounded-md bg-rose-700 px-6 py-3 text-white transition-colors duration-200 hover:bg-rose-800"
		>
			Go home
		</a>
	</section>
</Layout>
