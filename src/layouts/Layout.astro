---
import { ClientRouter, fade } from "astro:transitions";
import MainHead from "@/components/MainHead.astro";
import Nav from "@/components/Nav.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
---

<html lang="en" transition:animate="none">
	<head>
		<MainHead title={title} description={description} image={image} />
		<ClientRouter />
		<script is:inline>
			const theme =
				localStorage.getItem("theme") ||
				(window.matchMedia("(prefers-color-scheme: dark)").matches
					? "dark"
					: "light");
			document.documentElement.classList.add(theme);
			document.documentElement.setAttribute("data-theme", theme);
		</script>
	</head>
	<body
		transition:animate={fade({ duration: "0.25s" })}
		class="bg-white text-gray-800 dark:bg-gray-800 dark:text-gray-200"
	>
		<div class="flex min-h-screen flex-col antialiased">
			<Nav />
			<main class="flex-1">
				<slot />
			</main>
		</div>
	</body>
</html>
